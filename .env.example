# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Environment Variables Template
# LumindAd · Ad Performance Intelligence Platform v1.0
# Author: Elizabeth Díaz Familia · AI Data Scientist · Sustainable Intelligence & BI
#
# Instructions:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in values marked with  <CHANGE_ME>
#   3. NEVER commit .env to git  (it's in .gitignore)
#   4. For production, use GitHub Secrets or AWS Secrets Manager
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=LumindAd
APP_VERSION=1.0.0
# Options: development | staging | production
APP_ENV=development
LOG_LEVEL=debug
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY — Change all secrets before any deployment
# ─────────────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<CHANGE_ME>
JWT_SECRET=<CHANGE_ME>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL 15
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lumindad
POSTGRES_USER=lumindad
POSTGRES_PASSWORD=<CHANGE_ME>
# Full connection URL (used by FastAPI + Alembic)
DATABASE_URL=postgresql+asyncpg://lumindad:<CHANGE_ME>@localhost:5432/lumindad

# ─────────────────────────────────────────────────────────────────────────────
# CACHE + BROKER — Redis 7.2
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=<CHANGE_ME>
REDIS_URL=redis://:password@localhost:6379
REDIS_TTL_SECONDS=21600

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_CONCURRENCY=4
CELERY_LOGLEVEL=info
CELERY_TASK_SOFT_LIMIT=300
CELERY_TASK_HARD_LIMIT=600

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — FastAPI
# ─────────────────────────────────────────────────────────────────────────────
API_PORT=8000
API_V1_PREFIX=/api/v1
WORKERS=4
# CORS — comma-separated origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload pipeline
MAX_UPLOAD_SIZE_MB=100
CHUNK_SIZE=50000
UPLOAD_DIR=./uploads
# Allowed: csv,xlsx,xls,json,tsv,txt,parquet,avro,pdf,xml
ALLOWED_EXTENSIONS=csv,xlsx,xls,json,tsv,txt,parquet

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND — Vite / React 18
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_ML_URL=http://localhost:8001
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development
VITE_ENABLE_GREEN_AI=true
VITE_I18N_DEFAULT_LANG=en
VITE_UPLOAD_MAX_SIZE_MB=100
VITE_UPLOAD_CHUNK_SIZE=50000

# ─────────────────────────────────────────────────────────────────────────────
# ML INFERENCE SERVICE
# ─────────────────────────────────────────────────────────────────────────────
ML_PORT=8001
ML_SERVICE_URL=http://localhost:8001
MODEL_DIR=./ml/models
DEFAULT_MODEL=XGBoost
BATCH_SIZE_MAX=10000
SHAP_SAMPLE_SIZE=200
INFERENCE_TIMEOUT_S=30

# Calibrated thresholds (from lumindad_model_meta.json — do not change)
THRESHOLD_XGBOOST=0.3155
THRESHOLD_MLP=0.3637
THRESHOLD_LSTM=0.4435
THRESHOLD_CNN1D=0.4950
THRESHOLD_AUTOENCODER=0.1852

# TensorFlow
TF_CPP_MIN_LOG_LEVEL=3
TF_ENABLE_ONEDNN_OPTS=0
TF_NUM_INTEROP_THREADS=2
TF_NUM_INTRAOP_THREADS=4

# ─────────────────────────────────────────────────────────────────────────────
# GREEN AI — GHG Protocol Scope 2
# ─────────────────────────────────────────────────────────────────────────────
GREEN_AI_ENABLED=true
GREEN_AI_CPU_W=95
GREEN_AI_GPU_W=250
GREEN_AI_PUE=1.57
# Source: IEA Global Energy Review 2023 (kgCO2/kWh)
GREEN_AI_CARBON_INTENSITY=0.475
GREEN_AI_STANDARD=GHG_Protocol_Scope_2

# ─────────────────────────────────────────────────────────────────────────────
# AWS — Container registry + infrastructure
# ─────────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=<CHANGE_ME>
AWS_SECRET_ACCESS_KEY=<CHANGE_ME>
AWS_REGION=us-east-1
# Format: 123456789.dkr.ecr.us-east-1.amazonaws.com
AWS_ECR_REGISTRY=<CHANGE_ME>
AWS_S3_BUCKET=lumindad-uploads
AWS_S3_REGION=us-east-1

# Docker image tag used in docker-compose.prod.yml
IMAGE_TAG=latest

# ─────────────────────────────────────────────────────────────────────────────
# i18n — Internationalization (11 languages)
# ─────────────────────────────────────────────────────────────────────────────
I18N_LANGUAGES=en,es,pt,fr,ar,he,zh,ru,tr,ko,ja
I18N_DEFAULT=en
I18N_FALLBACK=en

# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_METRICS=true
METRICS_PATH=/metrics
# Sentry DSN (leave blank to disable)
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1

# ─────────────────────────────────────────────────────────────────────────────
# NOTIFICATIONS
# ─────────────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=<CHANGE_ME>

# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEV SHORTCUTS
# ─────────────────────────────────────────────────────────────────────────────
# Flower (Celery monitor) — http://localhost:5555
FLOWER_PORT=5555
# Postgres admin — http://localhost:5050 (optional)
PGADMIN_EMAIL=admin@lumindad.ai
PGADMIN_PASSWORD=<CHANGE_ME>
