{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",

  "name": "LumindAd — Enterprise Advertising Intelligence",
  "short_name": "LumindAd",
  "description": "AI-powered global advertising intelligence platform. 50+ countries, 11 languages, 8 ML/DL models.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
